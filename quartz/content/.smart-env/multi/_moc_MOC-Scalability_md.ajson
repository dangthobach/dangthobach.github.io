 QPS Restriction System","target":"Notion Knowledge/Note/How LinkedIn Scaled User Restriction System to 5 Million Queries Per Second","line":76},{"title":"Reddit: Notifications at Scale","target":"Notion Knowledge/Note/How Reddit Delivers Notifications to Tens of Millions of Users","line":78},{"title":"Slack: Billions of Daily Messages","target":"Notion Knowledge/Note/How Slack Supports Billions of Daily Messages","line":80},{"title":"Tinder: 1B Swipes/Day API Gateway","target":"Notion Knowledge/Note/How Tinder's API Gateway Handles A Billion Swipes Per Day","line":82},{"title":"Shopify Tech Stack","target":"Notion Knowledge/Note/Shopify Tech Stack","line":84},{"title":"The Modern Software Stack","target":"Notion Knowledge/Note/EP177- The Modern Software Stack","line":86},{"title":"MOC-Database","target":"MOC-Database","line":93},{"title":"MOC-Distributed-Systems","target":"MOC-Distributed-Systems","line":94},{"title":"MOC-System-Design","target":"MOC-System-Design","line":95},{"title":"Bài 16: Deployment","target":"Rust-Zero-To-Hero/Bai-16-Deployment","line":96}],"metadata":{"tags":["#moc","#scalability","#performance","#infrastructure"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:_moc/MOC-Scalability.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1gini9","at":1775934019739},"key":"_moc/MOC-Scalability.md#---frontmatter---","lines":[1,3],"size":61,"outlinks":[],"class_name":"SmartBlock"},
